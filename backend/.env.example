# Copy to .env and fill in. Docker Compose maps Postgres to host port 5433.
DATABASE_URL=postgresql+psycopg2://bookkeeping:bookkeeping@localhost:5433/bookkeeping

# Required for real AI classification (F2). Without it, the AI service falls back
# to a deterministic rule-based classifier so the app still runs offline.
ANTHROPIC_API_KEY=

# Model + confidence policy (FR-TRAN-1 / FR-HITL-1)
AI_MODEL=claude-opus-4-8
CONFIDENCE_THRESHOLD=0.90
